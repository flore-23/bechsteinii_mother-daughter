P-values 
```{r}
p_values_age_interaction_UA <- sapply(names(obs_coef_interaction_age_UA), function(name) {
  mean(perm_coefs_df_interaction_age_UA[[name]] >= obs_coef_interaction_age_UA[name])
})

#create result table 
# Convert obs_coef to a data frame
obs_df_interaction_age_UA <- data.frame(
  term = names(obs_coef_interaction_age_UA),
  observed = as.numeric(obs_coef_interaction_age_UA),
  stringsAsFactors = FALSE
)

# Compute permutation summary (mean, SD) for each coefficient
perm_summary_interaction_age_UA <- perm_coefs_df_interaction_age_UA %>%
  pivot_longer(cols = everything(), names_to = "term", values_to = "value") %>%
  group_by(term) %>%
  summarise(
    perm_mean = mean(value),
    perm_sd   = sd(value),
    .groups = "drop"
  )

# Combine with observed and p-values
final_table_interaction_age_UA <- obs_df_interaction_age_UA %>%
  left_join(perm_summary_interaction_age_UA, by = "term") %>%
  mutate(p_value = p_values_age_interaction_UA[term])

# Optional: order by observed effect
final_table_interaction_age_UA <- final_table_interaction_age_UA %>% arrange(desc(observed))

final_table_interaction_age_UA
