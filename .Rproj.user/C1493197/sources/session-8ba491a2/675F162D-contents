#add the "mother-unrelated_daughter" to the ultimate_pair_type variable, only when there is something in the pair_type_2 variable, otherwise don't change
edges_UA_final <- edges_UA_final %>%
  mutate(
    ultimate_pair_type = case_when(
      pair_type_2 == "mother-daughter" ~ "mother-daughter",
      pair_type_2 == "mother-unrelated-daughter" ~ "mother-unrelated-daughter",
      TRUE ~ ultimate_pair_type
    )
  )
```

##Model
```{r}
edges_UA_final$ultimate_pair_type <- as.factor(edges_UA_final$ultimate_pair_type)
edges_UA_final$ultimate_pair_type <- relevel(edges_UA_final$ultimate_pair_type , ref = "other")

#due to high correlation in the interaction model, we can center the "relation age"
edges_UA_final <- edges_UA_final %>%
  mutate(relation_age_c = relation_age - mean(relation_age, na.rm = TRUE))

model_age_UA <- glmmTMB(weight_beta ~ relation_age_c + ultimate_pair_type + colony_size + unknown_age +
                              (1 | pairID) + (1 | year),
                              data = edges_UA_final,
                              family = beta_family())

summary(model_age_UA)

model_age_interaction_UA <- glmmTMB(weight_beta ~ relation_age_c * ultimate_pair_type + colony_size + unknown_age +
                              (1 | pairID) + (1 | year),
                              data = edges_UA_final,
                              family = beta_family())

summary(model_age_interaction_UA)
