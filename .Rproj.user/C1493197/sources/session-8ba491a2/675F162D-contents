#Permutation - models
Would we observe an effect of pair type of this magnitude if mother–daughter labels were randomly assigned under the same social structure?

We can do a *label permutation*, --> Randomly reassign the “mother–daughter” labels among dyads, within year, while keeping the number of MD pairs per year fixed 

First, we can save the observed coefficients, for both models 
```{r}
#store coefficients
obs_coef_age_GB2 <- fixef(model_age_GB2)$cond[c(
  "relation_age_c",
  "ultimate_pair_typemother-unrelated-daughter",
  "ultimate_pair_typemother-daughter",
  "colony_size"
)]

obs_coef_interaction_age_GB2 <- fixef(model_age_interaction_GB2)$cond[c(
  "relation_age_c",
  "ultimate_pair_typemother-unrelated-daughter",
  "ultimate_pair_typemother-daughter",
  "colony_size",
  "relation_age_c:ultimate_pair_typemother-unrelated-daughter",
  "relation_age_c:ultimate_pair_typemother-daughter"
)]

```

*Label Permutations*
#### without interaction
```{r}
# Prepare storage
n_perm <- 100
perm_coefs_age_GB2 <- matrix(NA, nrow = n_perm, ncol = length(obs_coef_age_GB2))
colnames(perm_coefs_age_GB2) <- names(obs_coef_age_GB2)

set.seed(123)

for (i in 1:n_perm) {
  # Permute pair_type2 within year
  perm_data <- edges_GB2_final %>%
    group_by(year) %>%
    mutate(ultimate_pair_type_perm = sample(ultimate_pair_type)) %>%
    ungroup()
  
  # Refit model
  perm_model <- glmmTMB(weight_beta ~ relation_age_c + ultimate_pair_type_perm + colony_size + unknown_age +
                              (1 | pairID) + (1 | year),
                              data = perm_data,
                              family = beta_family())
  
  # Save the coefficients of interest
  perm_coefs_age_GB2[i, ] <- fixef(perm_model)$cond[c(
  "relation_age_c",
  "ultimate_pair_type_permmother-unrelated-daughter",
  "ultimate_pair_type_permmother-daughter",
  "colony_size"
  )]
}

# Convert to data frame
perm_coefs_df_age_GB2 <- as.data.frame(perm_coefs_age_GB2)

save(perm_coefs_df_age_GB2, file = here("results", "Q2_permutation_age_GB2.RData"))
```
P-values 
```{r}
p_values_age_GB2 <- sapply(names(obs_coef_age_GB2), function(name) {
  mean(perm_coefs_df_age_GB2[[name]] >= obs_coef_age_GB2[name])
})

#create result table 
# Convert obs_coef to a data frame
obs_df_age_GB2 <- data.frame(
  term = names(obs_coef_age_GB2),
  observed = as.numeric(obs_coef_age_GB2),
  stringsAsFactors = FALSE
)

# Compute permutation summary (mean, SD) for each coefficient
perm_summary_age_GB2 <- perm_coefs_df_age_GB2 %>%
  pivot_longer(cols = everything(), names_to = "term", values_to = "value") %>%
  group_by(term) %>%
  summarise(
    perm_mean = mean(value),
    perm_sd   = sd(value),
    .groups = "drop"
  )

# Combine with observed and p-values
final_table_age_GB2 <- obs_df_age_GB2 %>%
  left_join(perm_summary_age_GB2, by = "term") %>%
  mutate(p_value = p_values_age_GB2[term])

# Optional: order by observed effect
final_table_age_GB2 <- final_table_age_GB2 %>% arrange(desc(observed))

final_table_age_GB2
```
