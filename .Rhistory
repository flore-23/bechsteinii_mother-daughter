edges_GB2_full<-rbind(edge_G2013,edge_G2014,edge_G2015,edge_G2016,edge_G2017,edge_G2018,edge_G2019,edge_G2020,edge_G2021,edge_G2022,edge_G2023)
edges_GB2_full$weight<-as.numeric(edges_GB2_full$weight)
write.csv(edges_GB2_full, here("data","saved_matrices","GB2","full","full_edges_GB2.csv"), row.names = FALSE)
#first we create the pairID, that matches the mother-daugther file. (sorted)
edges_GB2_full <- edges_GB2_full %>%
mutate(
pairID = ifelse(
from < to,
paste(from, to, sep = "-"),
paste(to, from, sep = "-")
)
)
#now we calculate how many years each pair appears in the dataset
relation_age_GB2 <- edges_GB2_full %>%
group_by(pairID) %>%
summarise(years_present = n_distinct(year)) %>%
ungroup()
#filter the pairs that appears only for two years
edges_GB2_filtered <- edges_GB2_full %>%
left_join(relation_age_GB2, by = "pairID")
#by using the mother-daughter_GB2 file
mother_daughter_GB2 <- read.csv(here("data","mother_daughter_GB2.csv"))
edges_GB2_filtered <- edges_GB2_filtered %>%
mutate(
ultimate_pair_type = ifelse(
pairID %in% mother_daughter_GB2$pairID,
"mother-daughter",
"other"
)
)
write.csv(edges_GB2_full, here("data","saved_matrices","GB2","full","full_edges_GB2.csv"), row.names = FALSE)
#now we can add daughter age information, the first year corresponds to the year written in the mother-daughter file in the column "year"
mother_daughter_GB2 <- mother_daughter_GB2 %>%
mutate(pairID = as.character(pairID))
edges_GB2_filtered <- edges_GB2_filtered %>%
group_by(pairID) %>%
mutate(first_year = mother_daughter_GB2$year[match(pairID, mother_daughter_GB2$pairID)]) %>%
mutate(daughter_age = ifelse(
is.na(first_year),
NA_real_,
year - first_year + 1
)) %>%
ungroup()
#filter out the mother-daughter pairs where daughter age is 1 (first year), but keep when daughter age is NA too
edges_GB2_filtered <- edges_GB2_filtered %>%
filter(!(ultimate_pair_type == "mother-daughter" & daughter_age == 1))
edges_GB2_filtered <- edges_GB2_filtered %>%
group_by(pairID) %>%
mutate(first_year_overall = min(year)) %>%
ungroup() %>%
mutate(relation_age = ifelse(
ultimate_pair_type == "mother-daughter",
daughter_age,
year - first_year_overall + 1
))
edges_GB2_filtered <- edges_GB2_filtered %>%
group_by(pairID) %>%
mutate(unknown_age = ifelse(
ultimate_pair_type == "other" & first_year_overall == 2013,
TRUE,
FALSE
)) %>%
ungroup()
edges_GB2_filtered <- edges_GB2_filtered %>%
mutate(unknown_age = factor(unknown_age))
write.csv(edges_GB2_filtered, here("data","saved_matrices","edges_GB2_filtered_hyp2.csv"), row.names = FALSE)
# rescale for beta distribution
n <- nrow(edges_GB2_filtered)
edges_GB2_filtered <- edges_GB2_filtered %>%
mutate(weight_beta = (weight * (n - 1) + 0.5) / n)
colony_size_GB2 <- read.csv(here("data","saved_matrices","GB2","colony_size_df.csv"))
# add colony size
colony_size_GB2 <- colony_size_GB2 %>%
mutate(year = as.numeric(year))
edges_GB2_filtered <- edges_GB2_filtered %>%
left_join(colony_size_GB2, by = "year")
#center colony size
edges_GB2_filtered <- edges_GB2_filtered %>%
mutate(colony_size_c = scale(colony_size, center = TRUE, scale = FALSE))
mom_juv_GB2<-read.csv(here("data","saved_matrices","GB2","mom_juv_GB2.csv"),sep=",")
mom_juv_GB2$pair_type_2 <- mom_juv_GB2$pair_type
mom_juv_GB2$pair_type_2[mom_juv_GB2$pair_type_2== "mother-random-juvenile"] <- "mother-unrelated-daughter"
table(mom_juv_GB2$pair_type)
#add the "mother-random-juvenile" to the edge list
edges_GB2_final <- edges_GB2_filtered %>%
left_join(
mom_juv_GB2 %>% select(pairID, pair_type_2),
by = c("pairID")
)
#add the "mother-unrelated_daughter" to the ultimate_pair_type variable, only when there is something in the pair_type_2 variable, otherwise don't change
edges_GB2_final <- edges_GB2_final %>%
mutate(
ultimate_pair_type = case_when(
pair_type_2 == "mother-daughter" ~ "mother-daughter",
pair_type_2 == "mother-unrelated-daughter" ~ "mother-unrelated-daughter",
TRUE ~ ultimate_pair_type
)
)
edges_GB2_final$ultimate_pair_type <- as.factor(edges_GB2_final$ultimate_pair_type)
edges_GB2_final$ultimate_pair_type <- relevel(edges_GB2_final$ultimate_pair_type , ref = "other")
#due to high correlation in the interaction model, we can center the "relation age"
edges_GB2_final <- edges_GB2_final %>%
mutate(relation_age_c = relation_age - mean(relation_age, na.rm = TRUE))
model_age_GB2 <- glmmTMB(weight_beta ~ relation_age_c + ultimate_pair_type + colony_size + unknown_age +
(1 | pairID) + (1 | year),
data = edges_GB2_final,
family = beta_family())
summary(model_age_GB2)
model_age_interaction_GB2 <- glmmTMB(weight_beta ~ relation_age_c * ultimate_pair_type + colony_size + unknown_age +
(1 | pairID) + (1 | year),
data = edges_GB2_final,
family = beta_family())
summary(model_age_interaction_GB2)
model_age_interaction_GB2$estimate
summary(model_age_interaction_GB2)$estimate
obs_coef_interaction_age_GB2 <- fixef(model_age_interaction_GB2)$cond[c(
"relation_age_c",
"ultimate_pair_typemother-unrelated-daughter",
"ultimate_pair_typemother-daughter",
"colony_size",
"relation_age_c:ultimate_pair_typemother-unrelated-daughter",
"relation_age_c:ultimate_pair_typemother-daughter"
)]
obs_coef_interaction_age_GB2 <- fixef(model_age_interaction_GB2)$cond[c(
"relation_age_c",
"ultimate_pair_typemother-unrelated-daughter",
"ultimate_pair_typemother-daughter",
"colony_size",
"relation_age_c:ultimate_pair_typemother-unrelated-daughter",
"relation_age_c:ultimate_pair_typemother-daughter"
)]
obs_coef_interaction_age_GB2
# Permute pair_type2 within year
perm_data_interaction <- edges_GB2_final %>%
group_by(year) %>%
mutate(ultimate_pair_type = sample(ultimate_pair_type)) %>%
ungroup()
# Prepare storage
n_perm <- 50
perm_coefs_interaction_age_GB2 <- matrix(NA, nrow = n_perm, ncol = length(obs_coef_interaction_age_GB2 ))
colnames(perm_coefs_interaction_age_GB2 ) <- names(obs_coef_interaction_age_GB2 )
set.seed(123)
for (i in 1:n_perm) {
# Permute pair_type2 within year
perm_data_interaction <- edges_GB2_final %>%
group_by(year) %>%
mutate(ultimate_pair_type = sample(ultimate_pair_type)) %>%
ungroup()
# Refit model
perm_model_interaction_age_GB2 <- glmmTMB(weight_beta ~ relation_age_c * ultimate_pair_type + colony_size + unknown_age +
(1 | pairID) + (1 | year),
data = perm_data_interaction,
family = beta_family())
# Save the coefficients of interest
perm_coefs_interaction_age_GB2[i, ] <- fixef(perm_model_interaction_age_GB2)$cond[c(
"relation_age_c",
"ultimate_pair_type_mother-unrelated-daughter",
"ultimate_pair_type_mother-daughter",
"colony_size",
"relation_age_c:ultimate_pair_type_mother-unrelated-daughter",
"relation_age_c:ultimate_pair_type_mother-daughter"
)]
}
# Convert to data frame
perm_coefs_df_interaction_age_GB2 <- as.data.frame(perm_coefs_interaction_age_GB2)
save(perm_coefs_df_interaction_age_GB2, file = here("results", "Q2_permutation_interaction_age_GB2.RData"))
p_values_age_interaction_GB2 <- sapply(names(obs_coef_interaction_age_GB2), function(name) {
mean(perm_coefs_df_interaction_age_GB2[[name]] >= obs_coef_interaction_age_GB2[name])
})
#create result table
# Convert obs_coef to a data frame
obs_df_interaction_age_GB2 <- data.frame(
term = names(obs_coef_interaction_age_GB2),
observed = as.numeric(obs_coef_interaction_age_GB2),
stringsAsFactors = FALSE
)
# Compute permutation summary (mean, SD) for each coefficient
perm_summary_interaction_age_GB2 <- perm_coefs_df_interaction_age_GB2 %>%
pivot_longer(cols = everything(), names_to = "term", values_to = "value") %>%
group_by(term) %>%
summarise(
perm_mean = mean(value),
perm_sd   = sd(value),
.groups = "drop"
)
# Combine with observed and p-values
final_table_interaction_age_GB2 <- obs_df_interaction_age_GB2 %>%
left_join(perm_summary_interaction_age_GB2, by = "term") %>%
mutate(p_value = p_values_age_interaction_GB2[term])
# Optional: order by observed effect
final_table_interaction_age_GB2 <- final_table_interaction_age_GB2 %>% arrange(desc(observed))
final_table_interaction_age_GB2
